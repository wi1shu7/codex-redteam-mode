{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{SESSION_COMMAND}}",
            "commandWindows": "{{SESSION_COMMAND_WINDOWS}}",
            "statusMessage": "Loading session mode context",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PROMPT_COMMAND}}",
            "commandWindows": "{{PROMPT_COMMAND_WINDOWS}}",
            "statusMessage": "Checking mode-gated offensive routing",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{STOP_COMMAND}}",
            "commandWindows": "{{STOP_COMMAND_WINDOWS}}",
            "statusMessage": "Recording refusal backstop state",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
