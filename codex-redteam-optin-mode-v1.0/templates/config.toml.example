# Example only. Merge carefully into your real config.toml.
# Do not overwrite your full personal config unless you intend to.

[features]
codex_hooks = true

[mcp_servers.burp-ai-agent]
command = 'C:\Path\To\BurpSuite\jre\bin\java.exe'
args = ['-jar', 'C:\Path\To\mcp-proxy.jar', '--sse-url', 'http://127.0.0.1:9876']
enabled = true
startup_timeout_sec = 20
tool_timeout_sec = 120
